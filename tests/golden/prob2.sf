; Считаем разницу квадрата суммы квадратов и суммы квадратов первых N натуральных чисел
; Формула:
;     difference = N*(N - 1)*(N + 1)*(3*N+2)/12
; (по условию задачи N = 100)

@define N 100

    .text

_main:
  ( : $N )
  ( N : N, N )
  ( N : N, N )
  ( N : N, N )
  ( : 1 )
  ( n, one : n - one )
  ( n, n_minus_1 : n * n_minus_1 )

  ( acc, n : n, acc )
  ( : 1 )
  ( n, one : n + one )
  ( acc, n_plus_1 : acc * n_plus_1 )

  ( acc, n : n, acc )
  ( : 3 )
  ( n, three : n * three )
  ( : 2 )
  ( triple_n, two : triple_n + two )
  ( acc, term4 : acc * term4 )

  ( : 12 )
  ( numerator, denominator : numerator / denominator )
  <...>